# ─────────────────────────────────────────────────────────────────────────────
# MatchOracle — configuration. Copy to `.env` and adjust.
# ─────────────────────────────────────────────────────────────────────────────

# --- General ---
MO_ENV=development
MO_LOG_LEVEL=INFO
MO_API_PREFIX=/api/v1

# --- Database (PostgreSQL / TimescaleDB) ---
# In docker compose the host is `postgres`. Locally use `localhost`.
MO_DATABASE_URL=postgresql+psycopg://matchoracle:matchoracle@postgres:5432/matchoracle

# --- Cache (Redis) ---
MO_REDIS_URL=redis://redis:6379/0

# --- LLM provider (Sprint 04) ---
# Provider: "openai" or "ollama"
MO_LLM_PROVIDER=openai
MO_LLM_MODEL=gpt-4o-mini
MO_OPENAI_API_KEY=sk-replace-me
# Ollama (when MO_LLM_PROVIDER=ollama)
MO_OLLAMA_BASE_URL=http://ollama:11434
# Multi-model router policy (Sprint 12): "cost" | "quality" | "balanced"
MO_LLM_ROUTER_POLICY=balanced
MO_LLM_TIMEOUT_SECONDS=30
MO_LLM_MAX_RETRIES=2

# --- Orchestration weights (Sprint 05). JSON object, must sum to ~1.0 ---
MO_AGENT_WEIGHTS={"historical":0.25,"trend":0.20,"contextual":0.15,"risk":0.15,"market":0.10,"expert":0.15}

# --- Auto-weighting guardrails (Sprint 10) ---
MO_AUTOWEIGHT_ENABLED=true
MO_AUTOWEIGHT_LEARNING_RATE=0.1
MO_AUTOWEIGHT_MIN=0.02
MO_AUTOWEIGHT_MAX=0.6

# --- Distributed execution (Sprint 14) ---
MO_CELERY_BROKER_URL=redis://redis:6379/1
MO_CELERY_RESULT_BACKEND=redis://redis:6379/2
MO_DISTRIBUTED_AGENTS=false

# --- Auth / Multi-tenancy / RBAC (Sprint 13) ---
MO_AUTH_ENABLED=false
MO_JWT_SECRET=change-me-in-production-with-a-long-random-secret
MO_JWT_ALGORITHM=HS256
MO_JWT_EXPIRE_MINUTES=60
MO_DEFAULT_TENANT=public
# Secret backend: "env" (default) or "vault". With "vault", values are read from
# a Vault KV mount — never hard-coded. Start the dev Vault container with:
#   docker compose --profile enterprise up -d vault
MO_SECRETS_BACKEND=env
MO_VAULT_ADDR=http://vault:8200
MO_VAULT_TOKEN=

# --- MCP (Sprint 07) ---
# Comma-separated list of MCP server configs is loaded from config/mcp_servers.json
MO_MCP_ENABLED=true

# --- Connectors: football data (Sprint 08 / World Cup) ---
# Club football — OpenLigaDB (Bundesliga, no key needed)
MO_OPENLIGADB_BASE_URL=https://api.openligadb.de
MO_FOOTBALL_LEAGUE=bl1
MO_FOOTBALL_SEASON=2025
# World Cup live form/results — football-data.org (competition WC).
# Get a FREE key at https://www.football-data.org/client/register and paste below.
MO_FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
MO_FOOTBALL_DATA_API_KEY=
MO_WC_COMPETITION=WC

# --- Observability (Sprint 14) ---
MO_METRICS_ENABLED=true
